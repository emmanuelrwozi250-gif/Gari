generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                String    @id @default(cuid())
  name              String?
  email             String    @unique
  emailVerified     DateTime?
  phone             String?
  avatar            String?
  image             String?
  password          String?
  role              Role      @default(RENTER)
  nidaNumber        String?
  nidaVerified      Boolean   @default(false)
  licenseVerified   Boolean   @default(false)
  // Superhost & response metrics
  responseRate      Int       @default(100)
  avgResponseHours  Int       @default(2)
  superhostSince    DateTime?
  totalHostTrips    Int       @default(0)
  // Stripe Connect for host payouts
  stripeAccountId   String?
  stripeOnboarded   Boolean   @default(false)
  // WhatsApp & language preferences
  whatsappNumber    String?
  preferredLanguage String    @default("en")
  // Community Trust Circles
  saccoName         String?
  saccoMemberId     String?
  saccoVerified     Boolean   @default(false)
  trustScore        Int       @default(50)
  communityVerified Boolean   @default(false)
  trustCircleId     String?
  // Referral / agent system
  referralCode      String?   @unique
  referralEarnings  Int       @default(0)
  // Platform roles (can hold multiple)
  isSeller          Boolean   @default(false)
  isInvestor        Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts              Account[]
  sessions              Session[]
  cars                  Car[]
  bookings              Booking[]            @relation("RenterBookings")
  reviews               Review[]
  notifications         Notification[]
  sentMessages          Message[]            @relation("SentMessages")
  payoutRequests        PayoutRequest[]      @relation("HostPayouts")
  salesListings         SalesListing[]       @relation("SellerListings")
  salesEnquiries        SalesEnquiry[]       @relation("BuyerEnquiries")
  trustCircleMembership TrustCircleMember[]
  financingApplications FinancingApplication[]
  mapReports            MapReport[]            @relation("UserMapReports")
  poiInteractions       POIInteraction[]       @relation("UserPOIInteractions")
  mapPreferences        UserMapPreferences?    @relation("UserMapPreferences")
  kycVerification       RenterVerification?    @relation("UserKYC")
}

enum Role {
  RENTER
  HOST
  BOTH
  ADMIN
}

model Car {
  id                String        @id @default(cuid())
  hostId            String
  host              User          @relation(fields: [hostId], references: [id])
  make              String
  model             String
  year              Int
  type              CarType
  listingType       ListingType
  seats             Int
  transmission      Transmission
  fuel              FuelType
  pricePerDay       Int
  driverAvailable   Boolean       @default(false)
  driverPricePerDay Int?
  depositAmount     Int           @default(0)
  description       String        @db.Text
  features          String[]
  photos            String[]
  district          String
  exactLocation     String?
  lat               Float?
  lng               Float?
  slug              String?       @unique
  isAvailable       Boolean       @default(true)
  isVerified        Boolean       @default(false)
  instantBooking    Boolean       @default(false)
  mileageLimit      Int?
  fuelPolicy        String?
  smokingAllowed    Boolean       @default(false)
  hasAC             Boolean       @default(true)
  hasWifi           Boolean       @default(false)
  hasGPS            Boolean       @default(false)
  hasChildSeat      Boolean       @default(false)
  rating            Float         @default(0)
  totalTrips        Int           @default(0)
  // Gari 360 extensions
  vehicleValueRwf   Int           @default(0)
  source            VehicleSource @default(OWNER)
  forSale           Boolean       @default(false)
  salesPriceRwf     Int?
  salesStatus       SalesStatus?
  roiData           Json?
  pricingMode       String        @default("static")
  earlyBirdPct      Int           @default(0)
  minTrustScore     Int           @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  bookings          Booking[]
  reviews           Review[]
  availability      CarAvailability[]
  pricingSuggestions PricingSuggestion[]
  holds             BookingHold[]
}

enum CarType {
  ECONOMY
  SEDAN
  SUV_4X4
  EXECUTIVE
  MINIBUS
  PICKUP
  LUXURY
}

enum ListingType {
  P2P
  FLEET
}

enum Transmission {
  MANUAL
  AUTOMATIC
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  ELECTRIC
}

enum VehicleSource {
  OWNER
  GARI_SOURCED
}

enum SalesStatus {
  AVAILABLE
  RESERVED
  SOLD
}

enum ListingTier {
  BASIC
  STANDARD
  PREMIUM
}

model Booking {
  id                     String        @id @default(cuid())
  carId                  String
  car                    Car           @relation(fields: [carId], references: [id])
  renterId               String
  renter                 User          @relation("RenterBookings", fields: [renterId], references: [id])
  pickupDate             DateTime
  returnDate             DateTime
  withDriver             Boolean       @default(false)
  pickupLocation         String
  pickupLat              Float?
  pickupLng              Float?
  totalDays              Int
  subtotal               Int
  platformFee            Int
  driverFee              Int           @default(0)
  totalAmount            Int
  depositAmount          Int           @default(0)
  depositStatus          DepositStatus @default(HELD)
  status                 BookingStatus @default(PENDING)
  paymentMethod          PaymentMethod
  paymentStatus          PaymentStatus @default(UNPAID)
  momoTransactionId      String?
  stripePaymentIntentId  String?
  tipAmount              Int           @default(0)
  tipPaymentIntentId     String?
  inspectionPhotosPickup String[]
  inspectionPhotosReturn String[]
  inspectionReport       Json?
  damageReportPhotos     String[]
  damageDescription      String?
  cancellationReason     String?
  referralCircleId       String?
  referralCode           String?   // agent referral code used at booking
  referralCommission     Int       @default(0)
  notes                  String?
  reviewRequestSentAt    DateTime? // when review-reminder WhatsApp was sent
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  review    Review?
  messages  Message[]
  insurance Insurance?
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  MTN_MOMO
  AIRTEL_MONEY
  CARD
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum DepositStatus {
  HELD
  RELEASED
  CLAIMED
}

// Insurance certificate linked to a confirmed booking
model Insurance {
  id                     String   @id @default(cuid())
  bookingId              String   @unique
  booking                Booking  @relation(fields: [bookingId], references: [id])
  policyNumber           String   @unique
  insurerName            String
  coverageTier           String   @default("basic")
  vehicleCoverageRwf     Int
  thirdPartyLiabilityRwf Int      @default(5000000)
  claimsContact          String
  issuedAt               DateTime @default(now())
  certificateUrl         String?
}

model Review {
  id         String   @id @default(cuid())
  bookingId  String   @unique
  booking    Booking  @relation(fields: [bookingId], references: [id])
  carId      String
  car        Car      @relation(fields: [carId], references: [id])
  reviewerId String
  reviewer   User     @relation(fields: [reviewerId], references: [id])
  rating     Int
  comment    String   @db.Text
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// In-app messaging between renter and host per booking
model Message {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id])
  senderId  String
  sender    User     @relation("SentMessages", fields: [senderId], references: [id])
  content   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Host blocks dates their car is unavailable
model CarAvailability {
  id        String   @id @default(cuid())
  carId     String
  car       Car      @relation(fields: [carId], references: [id])
  startDate DateTime
  endDate   DateTime
  reason    String?
  createdAt DateTime @default(now())
}

// Host payout/withdrawal requests
model PayoutRequest {
  id          String       @id @default(cuid())
  hostId      String
  host        User         @relation("HostPayouts", fields: [hostId], references: [id])
  amount      Int
  status      PayoutStatus @default(PENDING)
  method      String       // MOMO, BANK, STRIPE
  accountRef  String?
  notes       String?
  processedAt DateTime?
  createdAt   DateTime     @default(now())
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

// ─── BOOKING HOLD — 10-minute slot lock to prevent double-bookings ─────────────

model BookingHold {
  id         String   @id @default(cuid())
  carId      String
  car        Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  sessionId  String   // anonymous client session identifier
  pickupDate DateTime
  returnDate DateTime
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([carId, pickupDate, returnDate])
  @@index([expiresAt])
}

// ─── BUY & SELL MARKETPLACE ────────────────────────────────────────────────────

model SalesListing {
  id              String      @id @default(cuid())
  sellerId        String
  seller          User        @relation("SellerListings", fields: [sellerId], references: [id])
  make            String
  model           String
  year            Int
  mileage         Int
  colour          String
  regNumber       String?
  transmission    Transmission
  fuel            FuelType
  type            CarType
  askingPrice     Int
  condition       String      // Excellent | Good | Fair | Needs Work
  district        String
  description     String      @db.Text
  photos          String[]
  ownershipProof  String?
  listingTier     ListingTier @default(BASIC)
  tierPaidAmount  Int         @default(0)
  status          SalesStatus @default(AVAILABLE)
  viewCount       Int         @default(0)
  featured        Boolean     @default(false)
  inspectionDone  Boolean     @default(false)
  inspectionUrl   String?
  alsoListForRent Boolean     @default(false)
  expiresAt       DateTime
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  enquiries SalesEnquiry[]
}

model SalesEnquiry {
  id          String       @id @default(cuid())
  listingId   String
  listing     SalesListing @relation(fields: [listingId], references: [id])
  buyerId     String?
  buyer       User?        @relation("BuyerEnquiries", fields: [buyerId], references: [id])
  buyerName   String
  buyerPhone  String
  buyerWA     String
  offerAmount Int?
  message     String?      @db.Text
  status      String       @default("new")
  createdAt   DateTime     @default(now())
}

// ─── BUY & EARN ────────────────────────────────────────────────────────────────

model BuyEarnListing {
  id                    String   @id @default(cuid())
  carId                 String?
  make                  String
  model                 String
  year                  Int
  type                  CarType
  photos                String[]
  purchasePriceRwf      Int
  repairCostRwf         Int      @default(0)
  registrationCostRwf   Int      @default(0)
  importDutiesRwf       Int      @default(0)
  comparableDailyRate   Int
  occupancyPct          Int      @default(65)
  maintenanceReservePct Int      @default(10)
  roiData               Json?
  roiConfidence         String   @default("medium")
  district              String
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  leads BuyEarnLead[]
}

model BuyEarnLead {
  id             String          @id @default(cuid())
  listingId      String?
  listing        BuyEarnListing? @relation(fields: [listingId], references: [id])
  name           String
  whatsapp       String
  email          String?
  budgetMin      Int
  budgetMax      Int
  preferredType  String
  timeline       String
  notes          String?         @db.Text
  status         String          @default("new")
  createdAt      DateTime        @default(now())
}

// ─── TRUST CIRCLES ─────────────────────────────────────────────────────────────

model TrustCircle {
  id             String   @id @default(cuid())
  name           String
  type           String   // sacco | employer | university | church
  adminUserId    String
  referralCode   String   @unique
  payoutAccount  String?
  totalEarnings  Int      @default(0)
  createdAt      DateTime @default(now())

  members TrustCircleMember[]
}

model TrustCircleMember {
  id       String      @id @default(cuid())
  circleId String
  circle   TrustCircle @relation(fields: [circleId], references: [id])
  userId   String
  user     User        @relation(fields: [userId], references: [id])
  status   String      @default("pending")
  joinedAt DateTime    @default(now())

  @@unique([circleId, userId])
}

// ─── DRIVE TO OWN FINANCING ────────────────────────────────────────────────────

model FinancingApplication {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  fullName       String
  nidaNumber     String
  monthlyIncome  Int
  desiredCarType String
  downPayment    Int
  timeline       String   @default("immediate")
  notes          String?  @db.Text
  status         String   @default("pending")
  bankReferredAt DateTime?
  createdAt      DateTime @default(now())
}

// ─── PRICING SUGGESTIONS ───────────────────────────────────────────────────────

model PricingSuggestion {
  id             String   @id @default(cuid())
  carId          String
  car            Car      @relation(fields: [carId], references: [id])
  suggestedPrice Int
  currentPrice   Int
  startDate      DateTime
  endDate        DateTime
  reason         String
  multiplier     Float
  status         String   @default("pending")
  appliedAt      DateTime?
  createdAt      DateTime @default(now())
}

// ─── MOBILITY INTELLIGENCE MAP ────────────────────────────────────────────────

enum KYCStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum MapReportType {
  TRAFFIC
  ACCIDENT
  POLICE
  ROADBLOCK
  FLOOD
  POTHOLE
}

model MapReport {
  id        String        @id @default(cuid())
  type      MapReportType
  lat       Float
  lng       Float
  userId    String?
  user      User?         @relation("UserMapReports", fields: [userId], references: [id])
  message   String?       @db.VarChar(200)
  upvotes   Int           @default(0)
  expiresAt DateTime
  createdAt DateTime      @default(now())
}

// ─── LIVE LOCATION AWARENESS ──────────────────────────────────────────────────

model POICache {
  id              String   @id @default(cuid())
  osmId           String   @unique
  name            String
  category        String   // food | hotel | landmark | religious | healthcare | transport | shopping
  subCategory     String?  // cafe | restaurant | hospital | etc.
  lat             Float
  lng             Float
  tags            Json
  isSponsored     Boolean  @default(false)
  sponsorPriority Int      @default(0)
  audioScript     String?  @db.Text
  viewCount       Int      @default(0)
  fetchedAt       DateTime @default(now())
  expiresAt       DateTime

  interactions POIInteraction[]
}

model POIInteraction {
  id        String    @id @default(cuid())
  poiId     String
  poi       POICache  @relation(fields: [poiId], references: [id])
  userId    String?
  user      User?     @relation("UserPOIInteractions", fields: [userId], references: [id])
  type      String    // viewed | announced | clicked | dismissed
  lat       Float?
  lng       Float?
  createdAt DateTime  @default(now())
}

model UserMapPreferences {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation("UserMapPreferences", fields: [userId], references: [id])
  audioEnabled Boolean  @default(false)
  categories   String[] @default(["food", "landmark", "healthcare"])
  frequency    String   @default("medium")
  radius       Int      @default(150)
  language     String   @default("en")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── RENTER KYC VERIFICATION ──────────────────────────────────────────────────

model RenterVerification {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation("UserKYC", fields: [userId], references: [id], onDelete: Cascade)
  idType           String    @default("NATIONAL_ID") // NATIONAL_ID or PASSPORT
  idPhotoFrontUrl  String?   // front of ID/passport
  idPhotoBackUrl   String?   // back of ID (not needed for passport)
  drivingPermitUrl String?   // driving permit photo
  selfieUrl        String?   // selfie with ID held up
  fullNameOnId     String?   // name as it appears on ID
  idNumber         String?   // ID or passport number
  status           KYCStatus @default(UNVERIFIED)
  rejectionReason  String?
  adminNotes       String?
  verifiedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}
