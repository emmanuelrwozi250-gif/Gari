generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                String    @id @default(cuid())
  name              String?
  email             String    @unique
  emailVerified     DateTime?
  phone             String?
  avatar            String?
  image             String?
  password          String?
  role              Role      @default(RENTER)
  nidaNumber        String?
  nidaVerified      Boolean   @default(false)
  licenseVerified   Boolean   @default(false)
  // Superhost & response metrics
  responseRate      Int       @default(100)
  avgResponseHours  Int       @default(2)
  superhostSince    DateTime?
  totalHostTrips    Int       @default(0)
  // Stripe Connect for host payouts
  stripeAccountId   String?
  stripeOnboarded   Boolean   @default(false)
  // WhatsApp & language preferences
  whatsappNumber    String?
  preferredLanguage String    @default("en")
  // Community Trust Circles
  saccoName         String?
  saccoMemberId     String?
  saccoVerified     Boolean   @default(false)
  trustScore        Int       @default(50)
  communityVerified Boolean   @default(false)
  trustCircleId     String?
  // Referral / agent system
  referralCode      String?   @unique
  referralEarnings  Int       @default(0)
  // Platform roles (can hold multiple)
  isSeller          Boolean   @default(false)
  isInvestor        Boolean   @default(false)
  // Repeat-offender / reputation
  renterRating      Float     @default(0)
  lateReturnCount   Int       @default(0)
  lateReturnFlaggedAt DateTime?
  suspendedUntil    DateTime?
  suspensionReason  String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts              Account[]
  sessions              Session[]
  cars                  Car[]
  bookings              Booking[]            @relation("RenterBookings")
  reviews               Review[]
  notifications         Notification[]
  sentMessages          Message[]            @relation("SentMessages")
  payoutRequests        PayoutRequest[]      @relation("HostPayouts")
  salesListings         SalesListing[]       @relation("SellerListings")
  salesEnquiries        SalesEnquiry[]       @relation("BuyerEnquiries")
  trustCircleMembership TrustCircleMember[]
  financingApplications FinancingApplication[]
  mapReports            MapReport[]            @relation("UserMapReports")
  poiInteractions       POIInteraction[]       @relation("UserPOIInteractions")
  mapPreferences        UserMapPreferences?    @relation("UserMapPreferences")
  kycVerification       RenterVerification?    @relation("UserKYC")
  hostReviewsGiven      HostReview[]           @relation("HostReviewsByHost")
  hostReviewsReceived   HostReview[]           @relation("HostReviewsAboutRenter")
  corporateAccountId    String?
  corporateAccount      CorporateAccount?      @relation("CorporateUsers", fields: [corporateAccountId], references: [id])
  corporateMemberships  CorporateMember[]      @relation("CorporateMemberships")
  corporateAdminOf      CorporateAccount[]     @relation("CorporateAdmin")
}

enum Role {
  RENTER
  HOST
  BOTH
  ADMIN
}

model Car {
  id                String        @id @default(cuid())
  hostId            String
  host              User          @relation(fields: [hostId], references: [id])
  make              String
  model             String
  year              Int
  type              CarType
  listingType       ListingType
  seats             Int
  transmission      Transmission
  fuel              FuelType
  pricePerDay       Int
  driverAvailable   Boolean       @default(false)
  driverPricePerDay Int?
  depositAmount     Int           @default(0)
  description       String        @db.Text
  features          String[]
  photos            String[]
  district          String
  exactLocation     String?
  lat               Float?
  lng               Float?
  slug              String?       @unique
  isAvailable       Boolean       @default(true)
  isVerified        Boolean       @default(false)
  instantBooking    Boolean       @default(false)
  mileageLimit      Int?
  fuelPolicy        String?
  smokingAllowed    Boolean       @default(false)
  hasAC             Boolean       @default(true)
  hasWifi           Boolean       @default(false)
  hasGPS            Boolean       @default(false)
  hasChildSeat      Boolean       @default(false)
  rating            Float         @default(0)
  totalTrips        Int           @default(0)
  // Gari 360 extensions
  vehicleValueRwf   Int           @default(0)
  source            VehicleSource @default(OWNER)
  forSale           Boolean       @default(false)
  salesPriceRwf     Int?
  salesStatus       SalesStatus?
  roiData           Json?
  pricingMode       String        @default("static")
  earlyBirdPct      Int           @default(0)
  minTrustScore     Int           @default(0)
  // New listing features
  isSafariCapable   Boolean       @default(false)
  isFeatured        Boolean       @default(false)
  featuredUntil     DateTime?
  minDays               Int                  @default(1)
  advanceNotice         Int                  @default(0)
  cancellationPolicy    CancellationPolicy   @default(MODERATE)
  createdAt             DateTime             @default(now())
  updatedAt         DateTime      @updatedAt

  bookings           Booking[]
  reviews            Review[]
  availability       CarAvailability[]
  pricingSuggestions PricingSuggestion[]
  holds              BookingHold[]
  images             CarImage[]
  blockedDates       BlockedDate[]
}

enum CarType {
  ECONOMY
  SEDAN
  SUV_4X4
  EXECUTIVE
  MINIBUS
  PICKUP
  LUXURY
  // Specialized / commercial
  TRUCK
  VAN
  COLD_TRUCK
  TRACTOR
  BUS
  MOTORBIKE
  AMBULANCE
  CONSTRUCTION
}

enum ListingType {
  P2P
  FLEET
}

enum Transmission {
  MANUAL
  AUTOMATIC
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  ELECTRIC
}

enum VehicleSource {
  OWNER
  GARI_SOURCED
}

enum SalesStatus {
  AVAILABLE
  RESERVED
  SOLD
}

enum ListingTier {
  BASIC
  STANDARD
  PREMIUM
}

model Booking {
  id                     String        @id @default(cuid())
  carId                  String
  car                    Car           @relation(fields: [carId], references: [id])
  renterId               String
  renter                 User          @relation("RenterBookings", fields: [renterId], references: [id])
  pickupDate             DateTime
  returnDate             DateTime
  withDriver             Boolean       @default(false)
  pickupLocation         String
  pickupLat              Float?
  pickupLng              Float?
  totalDays              Int
  subtotal               Int
  platformFee            Int
  driverFee              Int           @default(0)
  totalAmount            Int
  depositAmount          Int           @default(0)
  depositStatus          DepositStatus @default(HELD)
  status                 BookingStatus @default(PENDING)
  paymentMethod          PaymentMethod
  paymentStatus          PaymentStatus @default(UNPAID)
  momoTransactionId      String?
  stripePaymentIntentId  String?
  tipAmount              Int           @default(0)
  tipPaymentIntentId     String?
  inspectionPhotosPickup String[]
  inspectionPhotosReturn String[]
  inspectionReport       Json?
  damageReportPhotos     String[]
  damageDescription      String?
  cancellationReason     String?
  referralCircleId       String?
  referralCode           String?   // agent referral code used at booking
  referralCommission     Int       @default(0)
  notes                  String?
  reviewRequestSentAt    DateTime? // when review-reminder WhatsApp was sent
  // Host response tracking
  hostId                 String?
  hostResponseAt         DateTime?
  hostResponseDeadline   DateTime?
  hostRejectionReason    String?
  // Trip lifecycle
  tripStartedAt          DateTime?
  tripEndedAt            DateTime?
  carReturnedSafelyAt    DateTime?
  carReturnedSafelyBy    String?
  // Deposit tracking
  depositHeldAt          DateTime?
  depositRefundedAt      DateTime?
  depositRefundAmount    Int?
  depositWithheldAmount  Int?
  depositDisputeReason   String?
  // Cancellation & refund
  cancelledAt            DateTime?
  cancelledBy            String?
  refundAmount           Int?
  refundedAt             DateTime?
  completedAt            DateTime?
  totalWithDeposit       Int?
  insuranceFee           Int           @default(0)
  pickupLocationLabel    String?
  // ── late return tracking ────────────────────────────────────────
  gracePeriodMinutes     Int           @default(30)
  lateFeePerHour         Int           @default(5000)
  lateFeeAccrued         Int           @default(0)
  lateReturnReportedAt   DateTime?
  lateReturnResolvedAt   DateTime?
  // ── booking extension ───────────────────────────────────────────
  originalReturnDate     DateTime?
  extensions             BookingExtension[]
  // ── notification dedup sentAt timestamps ───────────────────────
  notif2hSentAt          DateTime?
  notif30mSentAt         DateTime?
  notifAtReturnSentAt    DateTime?
  notif30mLateSentAt     DateTime?
  notif1hLateSentAt      DateTime?
  hostNotifLateSentAt    DateTime?
  // ── renter on-my-way signal ─────────────────────────────────────
  renterOnMyWayAt        DateTime?
  renterOnMyWayMessage   String?
  // ── corporate billing ───────────────────────────────────────────
  corporateAccountId     String?
  corporateAccount       CorporateAccount? @relation("CorporateBookings", fields: [corporateAccountId], references: [id])
  corporateRef           String?   // PO number or job code
  costCenter             String?   // internal cost center
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  review           Review?
  hostReview       HostReview?
  messages         Message[]
  insurance        Insurance?
  refunds          Refund[]
  dispute          Dispute?
  inspectionPhotos InspectionPhoto[]
  notificationLogs NotificationLog[]
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
  REJECTED
  DISPUTED
}

enum PaymentMethod {
  MTN_MOMO
  AIRTEL_MONEY
  CARD
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  PARTIALLY_REFUNDED
  FULLY_REFUNDED
}

enum DepositStatus {
  HELD
  RELEASED
  CLAIMED
  NOT_APPLICABLE
  REFUNDED
  PARTIALLY_HELD
  WITHHELD
  DISPUTED
}

enum CancellationPolicy {
  FLEXIBLE
  MODERATE
  STRICT
}

// Insurance certificate linked to a confirmed booking
model Insurance {
  id                     String   @id @default(cuid())
  bookingId              String   @unique
  booking                Booking  @relation(fields: [bookingId], references: [id])
  policyNumber           String   @unique
  insurerName            String
  coverageTier           String   @default("basic")
  vehicleCoverageRwf     Int
  thirdPartyLiabilityRwf Int      @default(5000000)
  claimsContact          String
  issuedAt               DateTime @default(now())
  certificateUrl         String?
}

model Review {
  id         String    @id @default(cuid())
  bookingId  String    @unique
  booking    Booking   @relation(fields: [bookingId], references: [id])
  carId      String
  car        Car       @relation(fields: [carId], references: [id])
  reviewerId String
  reviewer   User      @relation(fields: [reviewerId], references: [id])
  rating     Int
  comment    String    @db.Text
  // Blind reveal — content shown only after both parties review or 14-day deadline
  isRevealed Boolean   @default(false)
  revealedAt DateTime?
  createdAt  DateTime  @default(now())
}

model HostReview {
  id           String    @id @default(cuid())
  bookingId    String    @unique
  booking      Booking   @relation(fields: [bookingId], references: [id])
  renterId     String
  renter       User      @relation("HostReviewsAboutRenter", fields: [renterId], references: [id])
  hostId       String
  host         User      @relation("HostReviewsByHost", fields: [hostId], references: [id])
  rating       Int
  comment      String    @db.Text
  reliability  Int?
  communication Int?
  respect      Int?
  isRevealed   Boolean   @default(false)
  revealedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([bookingId])
  @@index([renterId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// In-app messaging between renter and host per booking
model Message {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id])
  senderId  String
  sender    User     @relation("SentMessages", fields: [senderId], references: [id])
  content   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Host blocks dates their car is unavailable
model CarAvailability {
  id        String   @id @default(cuid())
  carId     String
  car       Car      @relation(fields: [carId], references: [id])
  startDate DateTime
  endDate   DateTime
  reason    String?
  createdAt DateTime @default(now())
}

// Host payout/withdrawal requests
model PayoutRequest {
  id          String       @id @default(cuid())
  hostId      String
  host        User         @relation("HostPayouts", fields: [hostId], references: [id])
  amount      Int
  status      PayoutStatus @default(PENDING)
  method      String       // MOMO, BANK, STRIPE
  accountRef  String?
  notes       String?
  processedAt DateTime?
  createdAt   DateTime     @default(now())
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

// ─── BOOKING HOLD — 10-minute slot lock to prevent double-bookings ─────────────

model BookingHold {
  id         String   @id @default(cuid())
  carId      String
  car        Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  sessionId  String   // anonymous client session identifier
  pickupDate DateTime
  returnDate DateTime
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([carId, pickupDate, returnDate])
  @@index([expiresAt])
}

// ─── BUY & SELL MARKETPLACE ────────────────────────────────────────────────────

model SalesListing {
  id              String      @id @default(cuid())
  sellerId        String
  seller          User        @relation("SellerListings", fields: [sellerId], references: [id])
  make            String
  model           String
  year            Int
  mileage         Int
  colour          String
  regNumber       String?
  transmission    Transmission
  fuel            FuelType
  type            CarType
  askingPrice     Int
  condition       String      // Excellent | Good | Fair | Needs Work
  district        String
  description     String      @db.Text
  photos          String[]
  ownershipProof  String?
  listingTier     ListingTier @default(BASIC)
  tierPaidAmount  Int         @default(0)
  status          SalesStatus @default(AVAILABLE)
  viewCount       Int         @default(0)
  featured        Boolean     @default(false)
  inspectionDone  Boolean     @default(false)
  inspectionUrl   String?
  alsoListForRent Boolean     @default(false)
  expiresAt       DateTime
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  enquiries SalesEnquiry[]
}

model SalesEnquiry {
  id          String       @id @default(cuid())
  listingId   String
  listing     SalesListing @relation(fields: [listingId], references: [id])
  buyerId     String?
  buyer       User?        @relation("BuyerEnquiries", fields: [buyerId], references: [id])
  buyerName   String
  buyerPhone  String
  buyerWA     String
  offerAmount Int?
  message     String?      @db.Text
  status      String       @default("new")
  createdAt   DateTime     @default(now())
}

// ─── BUY & EARN ────────────────────────────────────────────────────────────────

model BuyEarnListing {
  id                    String   @id @default(cuid())
  carId                 String?
  make                  String
  model                 String
  year                  Int
  type                  CarType
  photos                String[]
  purchasePriceRwf      Int
  repairCostRwf         Int      @default(0)
  registrationCostRwf   Int      @default(0)
  importDutiesRwf       Int      @default(0)
  comparableDailyRate   Int
  occupancyPct          Int      @default(65)
  maintenanceReservePct Int      @default(10)
  roiData               Json?
  roiConfidence         String   @default("medium")
  district              String
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  leads BuyEarnLead[]
}

model BuyEarnLead {
  id             String          @id @default(cuid())
  listingId      String?
  listing        BuyEarnListing? @relation(fields: [listingId], references: [id])
  name           String
  whatsapp       String
  email          String?
  budgetMin      Int
  budgetMax      Int
  preferredType  String
  timeline       String
  notes          String?         @db.Text
  status         String          @default("new")
  createdAt      DateTime        @default(now())
}

// ─── TRUST CIRCLES ─────────────────────────────────────────────────────────────

model TrustCircle {
  id             String   @id @default(cuid())
  name           String
  type           String   // sacco | employer | university | church
  adminUserId    String
  referralCode   String   @unique
  payoutAccount  String?
  totalEarnings  Int      @default(0)
  createdAt      DateTime @default(now())

  members TrustCircleMember[]
}

model TrustCircleMember {
  id       String      @id @default(cuid())
  circleId String
  circle   TrustCircle @relation(fields: [circleId], references: [id])
  userId   String
  user     User        @relation(fields: [userId], references: [id])
  status   String      @default("pending")
  joinedAt DateTime    @default(now())

  @@unique([circleId, userId])
}

// ─── DRIVE TO OWN FINANCING ────────────────────────────────────────────────────

model FinancingApplication {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  fullName       String
  nidaNumber     String
  monthlyIncome  Int
  desiredCarType String
  downPayment    Int
  timeline       String   @default("immediate")
  notes          String?  @db.Text
  status         String   @default("pending")
  bankReferredAt DateTime?
  createdAt      DateTime @default(now())
}

// ─── PRICING SUGGESTIONS ───────────────────────────────────────────────────────

model PricingSuggestion {
  id             String   @id @default(cuid())
  carId          String
  car            Car      @relation(fields: [carId], references: [id])
  suggestedPrice Int
  currentPrice   Int
  startDate      DateTime
  endDate        DateTime
  reason         String
  multiplier     Float
  status         String   @default("pending")
  appliedAt      DateTime?
  createdAt      DateTime @default(now())
}

// ─── MOBILITY INTELLIGENCE MAP ────────────────────────────────────────────────

enum KYCStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum MapReportType {
  TRAFFIC
  ACCIDENT
  POLICE
  ROADBLOCK
  FLOOD
  POTHOLE
}

model MapReport {
  id        String        @id @default(cuid())
  type      MapReportType
  lat       Float
  lng       Float
  userId    String?
  user      User?         @relation("UserMapReports", fields: [userId], references: [id])
  message   String?       @db.VarChar(200)
  upvotes   Int           @default(0)
  expiresAt DateTime
  createdAt DateTime      @default(now())
}

// ─── LIVE LOCATION AWARENESS ──────────────────────────────────────────────────

model POICache {
  id              String   @id @default(cuid())
  osmId           String   @unique
  name            String
  category        String   // food | hotel | landmark | religious | healthcare | transport | shopping
  subCategory     String?  // cafe | restaurant | hospital | etc.
  lat             Float
  lng             Float
  tags            Json
  isSponsored     Boolean  @default(false)
  sponsorPriority Int      @default(0)
  audioScript     String?  @db.Text
  viewCount       Int      @default(0)
  fetchedAt       DateTime @default(now())
  expiresAt       DateTime

  interactions POIInteraction[]
}

model POIInteraction {
  id        String    @id @default(cuid())
  poiId     String
  poi       POICache  @relation(fields: [poiId], references: [id])
  userId    String?
  user      User?     @relation("UserPOIInteractions", fields: [userId], references: [id])
  type      String    // viewed | announced | clicked | dismissed
  lat       Float?
  lng       Float?
  createdAt DateTime  @default(now())
}

model UserMapPreferences {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation("UserMapPreferences", fields: [userId], references: [id])
  audioEnabled Boolean  @default(false)
  categories   String[] @default(["food", "landmark", "healthcare"])
  frequency    String   @default("medium")
  radius       Int      @default(150)
  language     String   @default("en")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── REFUNDS ──────────────────────────────────────────────────────────────────

model Refund {
  id           String   @id @default(cuid())
  bookingId    String
  booking      Booking  @relation(fields: [bookingId], references: [id])
  amount       Int
  reason       String
  description  String?
  initiatedBy  String
  processedAt  DateTime?
  momoReference String?
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
}

// ─── DISPUTES ─────────────────────────────────────────────────────────────────

model Dispute {
  id              String    @id @default(cuid())
  bookingId       String    @unique
  booking         Booking   @relation(fields: [bookingId], references: [id])
  raisedBy        String
  reason          String
  description     String    @db.Text
  evidenceUrls    String[]  @default([])
  responseUrls    String[]  @default([])
  hostResponse    String?
  renterResponse  String?
  status          String    @default("OPEN")
  resolution      String?
  resolvedBy      String?
  resolvedAt      DateTime?
  depositDecision String?
  partialAmount   Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ─── INSPECTION PHOTOS ────────────────────────────────────────────────────────

model InspectionPhoto {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  type      String   // pickup | return | damage
  position  String   // front | rear | left | right | interior | other
  imageUrl  String
  takenAt   DateTime @default(now())
  lat       Float?
  lng       Float?

  @@index([bookingId])
}

// ─── CAR IMAGES ───────────────────────────────────────────────────────────────

model CarImage {
  id        String   @id @default(cuid())
  carId     String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([carId])
}

// ─── BLOCKED DATES ────────────────────────────────────────────────────────────

model BlockedDate {
  id        String   @id @default(cuid())
  carId     String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())

  @@index([carId, date])
}

// ─── RENTER KYC VERIFICATION ──────────────────────────────────────────────────

model RenterVerification {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation("UserKYC", fields: [userId], references: [id], onDelete: Cascade)
  idType           String    @default("NATIONAL_ID") // NATIONAL_ID or PASSPORT
  idPhotoFrontUrl  String?   // front of ID/passport
  idPhotoBackUrl   String?   // back of ID (not needed for passport)
  drivingPermitUrl String?   // driving permit photo
  selfieUrl        String?   // selfie with ID held up
  fullNameOnId     String?   // name as it appears on ID
  idNumber         String?   // ID or passport number
  status           KYCStatus @default(UNVERIFIED)
  rejectionReason  String?
  adminNotes       String?
  verifiedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ─── BOOKING EXTENSIONS ────────────────────────────────────────────────────────

model BookingExtension {
  id            String   @id @default(cuid())
  bookingId     String
  booking       Booking  @relation(fields: [bookingId], references: [id])
  requestedBy   String
  hoursAdded    Int
  newReturnDate DateTime
  feeCharged    Int
  paymentMethod String
  paymentRef    String?
  status        String   @default("CONFIRMED")
  createdAt     DateTime @default(now())

  @@index([bookingId])
}

// ─── NOTIFICATION LOG (audit trail) ───────────────────────────────────────────

enum NotifType {
  REMINDER_2H
  REMINDER_30M
  REMINDER_AT_TIME
  LATE_30M
  LATE_1H
  LATE_ESCALATION
  EXTENSION_CONFIRMED
  EXTENSION_HOST_NOTIF
  HOST_LATE_WARNING
  HOST_NO_SHOW_UNLOCK
  DEPOSIT_RELEASED
  DEPOSIT_DISPUTED
  BOOKING_ACCEPTED
  BOOKING_REJECTED
  DAMAGE_REPORTED
  DISPUTE_RESOLVED
}

model NotificationLog {
  id        String    @id @default(cuid())
  bookingId String?
  booking   Booking?  @relation(fields: [bookingId], references: [id])
  userId    String
  type      NotifType
  channel   String
  message   String    @db.Text
  sentAt    DateTime  @default(now())
  delivered Boolean   @default(false)
  errorMsg  String?

  @@index([bookingId])
  @@index([userId])
}

// ─── CORPORATE / NGO ACCOUNTS ─────────────────────────────────────────────────

model CorporateAccount {
  id             String    @id @default(cuid())
  orgName        String
  orgType        String    @default("CORPORATE") // CORPORATE | NGO | GOVERNMENT | SME
  taxId          String?
  billingAddress String?
  billingEmail   String
  contactName    String
  contactPhone   String?
  creditLimit    Int       @default(0)
  creditUsed     Int       @default(0)
  status         String    @default("PENDING") // PENDING | ACTIVE | SUSPENDED
  adminUserId    String
  adminUser      User      @relation("CorporateAdmin", fields: [adminUserId], references: [id])
  approvedAt     DateTime?
  approvedBy     String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  members  CorporateMember[]
  bookings Booking[]         @relation("CorporateBookings")
  users    User[]            @relation("CorporateUsers")
}

model CorporateMember {
  id                 String           @id @default(cuid())
  corporateAccountId String
  account            CorporateAccount @relation(fields: [corporateAccountId], references: [id], onDelete: Cascade)
  userId             String
  user               User             @relation("CorporateMemberships", fields: [userId], references: [id])
  role               String           @default("MEMBER") // ADMIN | MEMBER | VIEWER
  costCenter         String?
  monthlyLimit       Int?
  createdAt          DateTime         @default(now())

  @@unique([corporateAccountId, userId])
  @@index([corporateAccountId])
  @@index([userId])
}
